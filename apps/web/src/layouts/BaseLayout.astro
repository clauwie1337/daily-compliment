---
import '../styles/global.css';
import { STORAGE_KEYS } from '../lib/storage';

export interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL;

const prepaintScript = `(() => {
  try {
    const themeKey = ${JSON.stringify(STORAGE_KEYS.theme)};
    const themeSaved = localStorage.getItem(themeKey);
    if (themeSaved === 'light' || themeSaved === 'dark') {
      document.documentElement.setAttribute('data-theme', themeSaved);
    } else {
      document.documentElement.removeAttribute('data-theme');
    }

    const skinKey = ${JSON.stringify(STORAGE_KEYS.skin)};
    const skinSaved = localStorage.getItem(skinKey);

    // Default for new users: bathroom wisdom.
    // Persisted values:
    // - 'bathroom' => bathroom wisdom
    // - 'azulejo'  => Portuguese tile look
    // - 'default'  => Aurora
    if (skinSaved === 'default') {
      document.documentElement.removeAttribute('data-skin');
    } else if (skinSaved === 'azulejo') {
      document.documentElement.setAttribute('data-skin', 'azulejo');
    } else {
      // 'bathroom' or null/unknown => bathroom.
      document.documentElement.setAttribute('data-skin', 'bathroom');
    }
  } catch {
    // ignore
  }
})();`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Apply theme + skin before first paint -->
    <script is:inline set:html={prepaintScript} />

    <title>{title}</title>
  </head>
  <body>
    <main class="container app">
      <slot />
    </main>
  </body>
</html>
